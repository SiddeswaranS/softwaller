.tx-stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin:20px 0 0}
.tx-stat{padding:18px;border-left:3px solid var(--blue);background:#F7F9FF;border-radius:6px}
.tx-stat strong{display:block;font-size:18px;color:var(--ink);margin-bottom:4px;letter-spacing:-.3px}
.tx-stat span{font-size:13px;color:var(--muted);line-height:1.55}
.tx-tag{display:inline-block;padding:4px 10px;background:var(--blue-bg);color:var(--blue);border-radius:999px;font-size:12px;font-weight:600;margin-bottom:10px}
.tx-links{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}
.tx-links a{padding:8px 14px;border:1px solid var(--line);border-radius:999px;font-size:13px;color:var(--ink);text-decoration:none;transition:all .2s}
.tx-links a:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-bg)}
`}></style>
  <Fragment set:html={`
<section class="phero">
