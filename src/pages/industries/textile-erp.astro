.tx-steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;counter-reset:s}
.tx-step{border:1px solid var(--line);border-radius:14px;padding:22px;background:var(--white);position:relative}
.tx-step::before{counter-increment:s;content:counter(s);position:absolute;top:-14px;left:20px;width:32px;height:32px;border-radius:50%;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px}
.tx-step h3{font-size:15px;font-weight:700;color:var(--ink);margin:8px 0 6px}
