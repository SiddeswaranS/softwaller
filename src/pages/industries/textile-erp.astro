t="35" rx="8" fill="#EBF0FF" stroke="#C2CFFF" stroke-width="1"/><text x="320" y="212" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="600" fill="#1557FF">Garment</text><line x1="200" y1="192" x2="200" y2="245" stroke="#A7F3D0" stroke-width="1.5"/><rect x="160" y="245" width="80" height="35" rx="8" fill="#ECFDF5" stroke="#A7F3D0" stroke-width="1"/><text x="200" y="267" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="600" fill="#059669">Export Docs</text></svg>
