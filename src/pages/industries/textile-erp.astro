.tx-section p{font-size:15px;color:var(--muted);line-height:1.85;margin:0 0 14px}
.tx-section p strong{color:var(--ink)}
.tx-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px}
.tx-card{border:1px solid var(--line);border-radius:14px;padding:22px;background:var(--white);transition:border-color .2s,box-shadow .2s}
.tx-card:hover{border-color:var(--blue-br);box-shadow:0 6px 20px rgba(10,15,30,.06)}
.tx-card .tx-ic{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:14px}
