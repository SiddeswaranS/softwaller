.tx-card p{font-size:13.5px;color:var(--muted);line-height:1.7;margin:0}
.tx-table-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:14px;background:var(--white)}
.tx-table{width:100%;border-collapse:collapse;font-size:14px;min-width:680px}
