---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Custom School ERP for CBSE and State Schools in India | Softwaller";
const description = "Custom school ERP with student enrollment, fee collection, attendance, exams, transport, and parent portal. CBSE and State board ready. Live in 10 weeks.";
const canonical = "https://www.softwaller.com/products/school-management.html";
const ogImage = "https://www.softwaller.com/assets/og-image.jpg";
const ogTitle = "Custom School ERP for CBSE and State Schools in India | Softwaller";
const ogDescription = "Custom school ERP with enrollment, fees, attendance, exams, transport, and parent portal. CBSE and State board ready. 10 weeks.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.softwaller.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "https://www.softwaller.com/#services"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "School &amp; Institute Management"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "School & Institute Management",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Custom school ERP with student enrollment, fee collection, attendance, exams, transport, and parent portal. CBSE and State board ready. Live in 10 weeks.",
    "url": "https://www.softwaller.com/products/school-management.html",
    "provider": {
      "@type": "Organization",
      "name": "Softwaller Technologies Private Limited",
      "url": "https://www.softwaller.com"
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "INR",
      "description": "Free consultation"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does it cover admissions, fees, attendance, exams, and transport?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We cover the full school cycle: enquiry to admission, fee structures with discounts and concessions, biometric or RFID attendance, term and online exams, transport routes with GPS tracking, and parent communication."
        }
      },
      {
        "@type": "Question",
        "name": "Can parents pay fees online and see report cards?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Parents pay via UPI, cards, or net banking, get receipts on WhatsApp and email, see attendance, marks, homework, and circulars on the parent app for Android and iOS."
        }
      },
      {
        "@type": "Question",
        "name": "Does it support CBSE, ICSE, state board, and university-level institutions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The grading system, exam structure, and report card format are fully configurable for CBSE, ICSE, Cambridge, IB, state boards, polytechnics, and degree colleges."
        }
      },
      {
        "@type": "Question",
        "name": "How is data privacy and student data protection handled?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We follow DPDP Act 2023 norms: parental consent for minors, role-based access, encrypted backups, India data residency, and audit logs. We never share or sell student data."
        }
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} ogTitle={ogTitle} ogDescription={ogDescription} jsonLd={jsonLd}>
  <Fragment slot="head-css" set:html={`<link rel="stylesheet" href="../assets/product.min.css?v=1.0.3">`} />
  <style is:global slot="head-css" set:html={`
.faq-section{margin:48px 0 32px;padding:0}
.faq-section h2{font-size:22px;font-weight:800;color:var(--ink);letter-spacing:-.5px;margin:0 0 18px}
.faq-section p.faq-sub{font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.7}
.faq-item{border:1px solid var(--line);border-radius:12px;margin-bottom:10px;background:var(--white);transition:border-color .2s}
.faq-item:hover{border-color:var(--blue-br)}
.faq-item[open]{border-color:var(--blue-br);box-shadow:0 4px 16px rgba(10,15,30,.06)}
.faq-item summary{padding:18px 22px;font-size:15.5px;font-weight:700;color:var(--ink);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;line-height:1.5}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:'\\002B';font-size:22px;font-weight:400;color:var(--blue);flex-shrink:0;transition:transform .2s}
.faq-item[open] summary::after{content:'\\2212'}
.faq-item .faq-answer{padding:0 22px 20px;font-size:14.5px;color:var(--muted);line-height:1.8}
`}></style>
  <Fragment set:html={`
<section class="phero">
  <div class="phero-inner">
    <div class="phero-text">
      <div class="phero-icon" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-graduation-cap"></i></div>
      <h1>Custom School ERP for CBSE & State Board Institutions</h1>
      <p>Admissions, fees, biometric attendance, exam grading, and parent communication on one platform — built for CBSE, state board, and matriculation schools across India. Designed in Chennai. Live in 8–10 weeks.</p>
    </div>
    <div class="phero-visual">
      <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><rect width="400" height="300" rx="16" fill="#fff" stroke="#E4E7F0" stroke-width="1.5"/><rect x="20" y="20" width="360" height="32" rx="8" fill="#F5F3FF"/><text x="200" y="40" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="11" font-weight="700" fill="#7C3AED">School Dashboard — 2025-26</text><rect x="30" y="65" width="80" height="55" rx="8" fill="#EBF0FF" stroke="#C2CFFF" stroke-width="1"/><text x="70" y="87" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="18" font-weight="800" fill="#1557FF">1,240</text><text x="70" y="105" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Students</text><rect x="118" y="65" width="80" height="55" rx="8" fill="#ECFDF5" stroke="#A7F3D0" stroke-width="1"/><text x="158" y="87" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="18" font-weight="800" fill="#059669">92%</text><text x="158" y="105" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Attendance</text><rect x="206" y="65" width="80" height="55" rx="8" fill="#F5F3FF" stroke="#DDD6FE" stroke-width="1"/><text x="246" y="87" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="18" font-weight="800" fill="#7C3AED">68</text><text x="246" y="105" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Teachers</text><rect x="294" y="65" width="80" height="55" rx="8" fill="#FFF7ED" stroke="#FED7AA" stroke-width="1"/><text x="334" y="87" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="18" font-weight="800" fill="#EA580C">&#8377;18L</text><text x="334" y="105" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Fees Collected</text><rect x="30" y="132" width="170" height="70" rx="8" fill="#fff" stroke="#E4E7F0" stroke-width="1"/><text x="45" y="150" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">Exam Results — Class X</text><rect x="40" y="158" width="20" height="30" rx="3" fill="#EBF0FF"/><rect x="40" y="168" width="20" height="20" rx="3" fill="#1557FF"/><rect x="66" y="158" width="20" height="30" rx="3" fill="#EBF0FF"/><rect x="66" y="162" width="20" height="26" rx="3" fill="#1557FF"/><rect x="92" y="158" width="20" height="30" rx="3" fill="#EBF0FF"/><rect x="92" y="170" width="20" height="18" rx="3" fill="#1557FF"/><rect x="118" y="158" width="20" height="30" rx="3" fill="#EBF0FF"/><rect x="118" y="164" width="20" height="24" rx="3" fill="#1557FF"/><rect x="144" y="158" width="20" height="30" rx="3" fill="#EBF0FF"/><rect x="144" y="166" width="20" height="22" rx="3" fill="#1557FF"/><rect x="210" y="132" width="170" height="70" rx="8" fill="#fff" stroke="#E4E7F0" stroke-width="1"/><text x="225" y="150" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">Fee Status</text><rect x="220" y="160" width="150" height="12" rx="6" fill="#E4E7F0"/><rect x="220" y="160" width="120" height="12" rx="6" fill="#059669"/><text x="355" y="170" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#059669">80%</text><text x="220" y="190" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">Paid: 992 | Pending: 248</text><rect x="30" y="215" width="340" height="60" rx="8" fill="#F7F8FC" stroke="#E4E7F0" stroke-width="1"/><text x="50" y="235" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">Today's Timetable — Class X-A</text><rect x="40" y="245" width="55" height="20" rx="4" fill="#EBF0FF"/><text x="67" y="258" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" font-weight="600" fill="#1557FF">Maths</text><rect x="102" y="245" width="55" height="20" rx="4" fill="#ECFDF5"/><text x="130" y="258" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" font-weight="600" fill="#059669">Science</text><rect x="164" y="245" width="55" height="20" rx="4" fill="#F5F3FF"/><text x="192" y="258" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" font-weight="600" fill="#7C3AED">English</text><rect x="226" y="245" width="55" height="20" rx="4" fill="#FFF7ED"/><text x="254" y="258" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" font-weight="600" fill="#EA580C">Hindi</text><rect x="288" y="245" width="55" height="20" rx="4" fill="#FDF2F8"/><text x="316" y="258" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" font-weight="600" fill="#DB2777">Sports</text></svg>
    </div>
