        <meta itemprop="position" content="1">
        <div class="feat-ic" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-user-plus"></i></div>
        <div class="feat-body">
          <span class="feat-num">01</span>
          <h3 itemprop="name">Student Enrollment</h3>
          <p itemprop="description">Online admission with form, document upload, and fee payment. Paperless enrollment from inquiry to confirmation.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="2">
        <div class="feat-ic" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-indian-rupee-sign"></i></div>
        <div class="feat-body">
          <span class="feat-num">02</span>
          <h3 itemprop="name">Fee Management</h3>
          <p itemprop="description">Fee collection with online payment, receipts, and defaulter tracking. Automated reminders for pending dues.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="3">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-clipboard-user"></i></div>
        <div class="feat-body">
          <span class="feat-num">03</span>
          <h3 itemprop="name">Attendance</h3>
          <p itemprop="description">Student and staff attendance with biometric or app-based marking. Daily reports sent to parents automatically.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="4">
        <div class="feat-ic" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-file-signature"></i></div>
        <div class="feat-body">
          <span class="feat-num">04</span>
          <h3 itemprop="name">Exam & Report Cards</h3>
          <p itemprop="description">Exam scheduling, mark entry, grade calculation, and report cards. Generate hundreds of report cards in minutes.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="5">
        <div class="feat-ic" style="background:var(--pink-bg);color:var(--pink)"><i class="fa-solid fa-people-roof"></i></div>
        <div class="feat-body">
          <span class="feat-num">05</span>
          <h3 itemprop="name">Parent Portal</h3>
          <p itemprop="description">Parents can view attendance, grades, fees, and communicate with teachers. Complete transparency builds trust.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="6">
        <div class="feat-ic" style="background:var(--cyan-bg);color:var(--cyan)"><i class="fa-solid fa-table-cells-large"></i></div>
        <div class="feat-body">
          <span class="feat-num">06</span>
          <h3 itemprop="name">Timetable Scheduling</h3>
          <p itemprop="description">Auto-generate timetables with teacher and room allocation. Handle substitutions and special events effortlessly.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
