        <meta itemprop="position" content="8">
        <div class="feat-ic" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-bus"></i></div>
        <div class="feat-body">
          <span class="feat-num">08</span>
          <h3 itemprop="name">Transport Management</h3>
          <p itemprop="description">Bus routes, vehicle tracking, and student pickup alerts. Parents know exactly when the bus arrives.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="9">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-chalkboard-user"></i></div>
        <div class="feat-body">
          <span class="feat-num">09</span>
          <h3 itemprop="name">Staff Management</h3>
          <p itemprop="description">Teacher profiles, workload, leave, and performance tracking. Streamline HR for your entire teaching staff.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="10">
        <div class="feat-ic" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-bullhorn"></i></div>
        <div class="feat-body">
          <span class="feat-num">10</span>
          <h3 itemprop="name">Communication</h3>
          <p itemprop="description">SMS, email, and push notifications to parents and staff. Instant announcements, circulars, and event updates.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="11">
        <div class="feat-ic" style="background:var(--pink-bg);color:var(--pink)"><i class="fa-solid fa-pen-to-square"></i></div>
        <div class="feat-body">
          <span class="feat-num">11</span>
          <h3 itemprop="name">Homework & Assignments</h3>
          <p itemprop="description">Teachers can assign and grade homework digitally. Students submit online and get feedback faster.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="12">
        <div class="feat-ic" style="background:var(--cyan-bg);color:var(--cyan)"><i class="fa-solid fa-certificate"></i></div>
        <div class="feat-body">
          <span class="feat-num">12</span>
          <h3 itemprop="name">Certificate Generation</h3>
          <p itemprop="description">Auto-generate TC, bonafide, and custom certificates. Branded templates with digital signatures and QR verification.</p>
        </div>
      </li>
    </ol>
  </div>
</section>

