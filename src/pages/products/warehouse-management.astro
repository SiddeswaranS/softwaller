          <p itemprop="description">Goods receipt with quality inspection checkpoints. Verify quantities, check conditions, and flag discrepancies instantly.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="10">
        <div class="feat-ic" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-right-left"></i></div>
