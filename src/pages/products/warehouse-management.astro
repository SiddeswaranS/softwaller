      <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><rect width="400" height="300" rx="16" fill="#fff" stroke="#E4E7F0" stroke-width="1.5"/><rect x="20" y="20" width="360" height="32" rx="8" fill="#FFF7ED"/><text x="200" y="40" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="11" font-weight="700" fill="#EA580C">Warehouse Operations</text><rect x="30" y="65" width="160" height="100" rx="8" fill="#F7F8FC" stroke="#E4E7F0" stroke-width="1"/><text x="110" y="82" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#EA580C">Pick List #PK-847</text><rect x="38" y="90" width="144" height="18" rx="4" fill="#ECFDF5"/><text x="46" y="103" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#059669">&#10003; SKU-001 — Bin A-12</text><rect x="38" y="112" width="144" height="18" rx="4" fill="#ECFDF5"/><text x="46" y="125" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#059669">&#10003; SKU-034 — Bin B-05</text><rect x="38" y="134" width="144" height="18" rx="4" fill="#FFF7ED"/><text x="46" y="147" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#EA580C">&#9723; SKU-112 — Bin C-08</text><rect x="210" y="65" width="160" height="100" rx="8" fill="#F7F8FC" stroke="#E4E7F0" stroke-width="1"/><text x="290" y="82" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#1557FF">Zones Overview</text><rect x="218" y="92" width="44" height="30" rx="4" fill="#EBF0FF"/><text x="240" y="112" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#1557FF">A: 94%</text><rect x="268" y="92" width="44" height="30" rx="4" fill="#ECFDF5"/><text x="290" y="112" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#059669">B: 67%</text><rect x="318" y="92" width="44" height="30" rx="4" fill="#FFF7ED"/><text x="340" y="112" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#EA580C">C: 42%</text><rect x="218" y="130" width="144" height="10" rx="5" fill="#E4E7F0"/><rect x="218" y="130" width="100" height="10" rx="5" fill="#1557FF"/><text x="330" y="138" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">68%</text><rect x="30" y="180" width="340" height="95" rx="8" fill="#F7F8FC" stroke="#E4E7F0" stroke-width="1"/><text x="50" y="200" font-family="'Plus Jakarta Sans',sans-serif" font-size="10" font-weight="700" fill="#0A0F1E">Shipments Today</text><rect x="40" y="210" width="70" height="50" rx="6" fill="#ECFDF5" stroke="#A7F3D0" stroke-width="1"/><text x="75" y="232" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="16" font-weight="800" fill="#059669">28</text><text x="75" y="248" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Dispatched</text><rect x="120" y="210" width="70" height="50" rx="6" fill="#FFF7ED" stroke="#FED7AA" stroke-width="1"/><text x="155" y="232" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="16" font-weight="800" fill="#EA580C">12</text><text x="155" y="248" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Packing</text><rect x="200" y="210" width="70" height="50" rx="6" fill="#EBF0FF" stroke="#C2CFFF" stroke-width="1"/><text x="235" y="232" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="16" font-weight="800" fill="#1557FF">7</text><text x="235" y="248" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Receiving</text><rect x="280" y="210" width="70" height="50" rx="6" fill="#FDF2F8" stroke="#FBCFE8" stroke-width="1"/><text x="315" y="232" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="16" font-weight="800" fill="#DB2777">3</text><text x="315" y="248" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Returns</text></svg>
    </div>
