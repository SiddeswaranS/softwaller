      <div class="pwhy-item">
        <i class="fa-solid fa-sliders"></i>
        <div><h3>Built for Your Workflow</h3><p>Custom-designed to match how your team actually works.</p></div>
      </div>
      <div class="pwhy-item">
        <i class="fa-solid fa-arrow-up-right-dots"></i>
        <div><h3>Scale as You Grow</h3><p>Architecture designed to handle 500+ concurrent users.</p></div>
      </div>
      <div class="pwhy-item">
        <i class="fa-solid fa-mobile-screen"></i>
        <div><h3>Mobile Ready</h3><p>Access from any device, anywhere, anytime.</p></div>
      </div>
      <div class="pwhy-item">
        <i class="fa-solid fa-plug"></i>
        <div><h3>Integration Ready</h3><p>Connect with Tally, WhatsApp, payment gateways, and more.</p></div>
      </div>
      <div class="pwhy-item">
        <i class="fa-solid fa-headset"></i>
        <div><h3>Ongoing Support</h3><p>3 months free support + AMC options after go-live.</p></div>
      </div>
      <div class="pwhy-item">
        <i class="fa-solid fa-shield-halved"></i>
        <div><h3>Data Security</h3><p>Role-based access, encryption, and audit trails.</p></div>
      </div>
    </div>
  </div>
</section>

