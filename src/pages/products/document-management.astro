amily="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#0A0F1E">ISO-Cert-2026.pdf</text><text x="200" y="270" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">3d ago</text><text x="300" y="270" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">v2.0</text><rect x="338" y="262" width="24" height="12" rx="3" fill="#FFF7ED"/><text x="350" y="271" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="6" font-weight="600" fill="#EA580C">⏳</text></svg>
