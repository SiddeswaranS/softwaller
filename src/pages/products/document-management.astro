---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Custom DMS with OCR Search and Approval Workflows | Softwaller";
const description = "Custom DMS with OCR full-text search, version control, role-based access, and digital approval workflows. DPDP-compliant. Cloud or on-premise. 8 weeks.";
const canonical = "https://www.softwaller.com/products/document-management.html";
const ogImage = "https://www.softwaller.com/assets/og-image.jpg";
const ogTitle = "Custom DMS with OCR Search and Approval Workflows | Softwaller";
const ogDescription = "Custom DMS with OCR full-text search, version control, role-based access, and digital approval workflows. DPDP-compliant. 8 weeks.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.softwaller.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "https://www.softwaller.com/#services"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Document Management (DMS)"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Document Management (DMS)",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Custom DMS with OCR full-text search, version control, role-based access, and digital approval workflows. DPDP-compliant. Cloud or on-premise. 8 weeks.",
    "url": "https://www.softwaller.com/products/document-management.html",
    "provider": {
      "@type": "Organization",
      "name": "Softwaller Technologies Private Limited",
      "url": "https://www.softwaller.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is search faster than just using a shared Google Drive or OneDrive?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We index document content using OCR, so searches find text inside scanned PDFs, photos, and old DOC files. Metadata fields (project, client, type, date) and saved searches cut document retrieval time from minutes to seconds."
        }
      },
      {
        "@type": "Question",
        "name": "Does it support version control and audit trail?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Every edit creates a new version with the editor's name, timestamp, and change summary. Older versions are restorable. Full audit logs cover who viewed, downloaded, edited, or shared each file."
        }
      },
      {
        "@type": "Question",
        "name": "Can we set permissions by folder, document, or department?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Role-based access works at folder, sub-folder, document, and even page level for PDFs. Departments only see what they need; sensitive documents (HR, legal, finance) stay restricted."
        }
      },
      {
        "@type": "Question",
        "name": "Is it compliant with DPDP Act and ISO 27001 norms?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We support encryption at rest and in transit, India data residency, consent capture for personal data, retention policies, audit logs, and the access controls required by DPDP Act 2023 and ISO 27001."
        }
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} ogTitle={ogTitle} ogDescription={ogDescription} jsonLd={jsonLd}>
  <Fragment slot="head-css" set:html={`<link rel="stylesheet" href="/assets/product.min.css?v=1.0.9">`} />
  <style is:global slot="head-css" set:html={`
.faq-section{margin:48px 0 32px;padding:0}
.faq-section h2{font-size:22px;font-weight:800;color:var(--ink);letter-spacing:-.5px;margin:0 0 18px}
.faq-section p.faq-sub{font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.7}
.faq-item{border:1px solid var(--line);border-radius:12px;margin-bottom:10px;background:var(--white);transition:border-color .2s}
.faq-item:hover{border-color:var(--blue-br)}
.faq-item[open]{border-color:var(--blue-br);box-shadow:0 4px 16px rgba(10,15,30,.06)}
.faq-item summary{padding:18px 22px;font-size:15.5px;font-weight:700;color:var(--ink);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;line-height:1.5}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:'\\002B';font-size:22px;font-weight:400;color:var(--blue);flex-shrink:0;transition:transform .2s}
.faq-item[open] summary::after{content:'\\2212'}
.faq-item .faq-answer{padding:0 22px 20px;font-size:14.5px;color:var(--muted);line-height:1.8}
`}></style>
  <Fragment set:html={`
<section class="phero">
