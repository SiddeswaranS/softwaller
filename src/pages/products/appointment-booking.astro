---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Custom Appointment Booking Software | Softwaller";
const description = "Custom appointment booking with calendar sync, SMS and WhatsApp Business reminders, payment collection, and multi-location scheduling. Live in 4 weeks.";
const canonical = "https://www.softwaller.com/products/appointment-booking.html";
const ogImage = "https://www.softwaller.com/assets/og-image.jpg";
const ogTitle = "Custom Appointment Booking Software with SMS Reminders | Softwaller";
const ogDescription = "Custom appointment booking with calendar sync, SMS and WhatsApp Business reminders, payment collection, and multi-location scheduling. 4 weeks.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.softwaller.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "https://www.softwaller.com/#services"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Appointment &amp; Booking System"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Appointment & Booking System",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Custom appointment booking with calendar sync, SMS and WhatsApp Business reminders, payment collection, and multi-location scheduling. Live in 4 weeks.",
    "url": "https://www.softwaller.com/products/appointment-booking.html",
    "provider": {
      "@type": "Organization",
      "name": "Softwaller Technologies Private Limited",
      "url": "https://www.softwaller.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does online booking reduce no-shows?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Automated SMS and WhatsApp reminders 24 hours and 1 hour before the appointment cut no-shows by 30 to 50 percent in our customer base. Customers can also reschedule from the reminder link without calling."
        }
      },
      {
        "@type": "Question",
        "name": "Can it sync with Google Calendar and Outlook?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Two-way sync with Google Calendar, Outlook, and Apple Calendar means staff see all appointments in one place and external blocks (lunch, holidays) reflect as unavailable in booking."
        }
      },
      {
        "@type": "Question",
        "name": "Does it handle multi-staff and multi-location businesses?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Each staff member has their own schedule, services, and availability. Customers pick a location first, then a service, then a staff member, all in one booking flow."
        }
      },
      {
        "@type": "Question",
        "name": "Can customers pay during booking?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Razorpay, Cashfree, PhonePe, and UPI payment links are integrated. You can set full payment, partial advance, or pay-at-venue per service type."
        }
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} ogTitle={ogTitle} ogDescription={ogDescription} jsonLd={jsonLd}>
  <Fragment slot="head-css" set:html={`<link rel="stylesheet" href="../assets/product.min.css?v=1.0.3">`} />
  <style is:global slot="head-css" set:html={`
.faq-section{margin:48px 0 32px;padding:0}
.faq-section h2{font-size:22px;font-weight:800;color:var(--ink);letter-spacing:-.5px;margin:0 0 18px}
.faq-section p.faq-sub{font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.7}
.faq-item{border:1px solid var(--line);border-radius:12px;margin-bottom:10px;background:var(--white);transition:border-color .2s}
.faq-item:hover{border-color:var(--blue-br)}
.faq-item[open]{border-color:var(--blue-br);box-shadow:0 4px 16px rgba(10,15,30,.06)}
.faq-item summary{padding:18px 22px;font-size:15.5px;font-weight:700;color:var(--ink);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;line-height:1.5}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:'\\002B';font-size:22px;font-weight:400;color:var(--blue);flex-shrink:0;transition:transform .2s}
.faq-item[open] summary::after{content:'\\2212'}
.faq-item .faq-answer{padding:0 22px 20px;font-size:14.5px;color:var(--muted);line-height:1.8}
`}></style>
  <Fragment set:html={`
<section class="phero">
  <div class="phero-inner">
    <div class="phero-text">
      <div class="phero-icon" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-calendar-check"></i></div>
      <h1>Custom Appointment Booking with SMS & WhatsApp Business Reminders</h1>
      <p>24/7 online booking, automated SMS and WhatsApp Business reminders, calendar sync, and payment-gateway-ready deposits. Built for Indian clinics, salons, and service providers. Live in 6–8 weeks.</p>
    </div>
    <div class="phero-visual">
      <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><rect width="400" height="300" rx="16" fill="#fff" stroke="#E4E7F0" stroke-width="1.5"/><rect x="20" y="20" width="200" height="260" rx="10" fill="#ECFDF5" stroke="#A7F3D0" stroke-width="1"/><text x="120" y="44" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="11" font-weight="700" fill="#059669">March 2026</text><g font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694" text-anchor="middle"><text x="42" y="65">Mo</text><text x="68" y="65">Tu</text><text x="94" y="65">We</text><text x="120" y="65">Th</text><text x="146" y="65">Fr</text><text x="172" y="65">Sa</text><text x="198" y="65">Su</text></g><g font-family="'Plus Jakarta Sans',sans-serif" font-size="9" text-anchor="middle" fill="#0A0F1E"><text x="172" y="84">1</text><text x="198" y="84">2</text><text x="42" y="102">3</text><text x="68" y="102">4</text><text x="94" y="102">5</text><text x="120" y="102">6</text><text x="146" y="102">7</text><text x="172" y="102">8</text><text x="198" y="102">9</text><text x="42" y="120">10</text><text x="68" y="120">11</text><text x="94" y="120">12</text><text x="120" y="120">13</text><text x="146" y="120">14</text><text x="172" y="120">15</text><text x="198" y="120">16</text></g><circle cx="120" cy="98" r="12" fill="#059669" opacity=".15"/><circle cx="68" cy="116" r="12" fill="#059669" opacity=".15"/><circle cx="146" cy="116" r="12" fill="#1557FF" opacity=".15"/><rect x="30" y="138" width="180" height="32" rx="6" fill="#fff" stroke="#A7F3D0" stroke-width="1"/><circle cx="46" cy="154" r="8" fill="#059669"/><text x="46" y="158" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="700" fill="#fff">&#10003;</text><text x="62" y="150" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#0A0F1E">9:00 — Dr. Sharma</text><text x="62" y="163" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Dental Checkup</text><rect x="30" y="178" width="180" height="32" rx="6" fill="#fff" stroke="#C2CFFF" stroke-width="1"/><circle cx="46" cy="194" r="8" fill="#1557FF"/><text x="46" y="198" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="700" fill="#fff">2</text><text x="62" y="190" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#0A0F1E">11:30 — Ms. Priya</text><text x="62" y="203" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Hair Consultation</text><rect x="30" y="218" width="180" height="32" rx="6" fill="#fff" stroke="#FED7AA" stroke-width="1"/><circle cx="46" cy="234" r="8" fill="#EA580C"/><text x="46" y="238" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="700" fill="#fff">3</text><text x="62" y="230" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#0A0F1E">2:00 — Mr. Ravi</text><text x="62" y="243" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">Spa Treatment</text><rect x="240" y="20" width="140" height="260" rx="10" fill="#fff" stroke="#E4E7F0" stroke-width="1"/><text x="310" y="44" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="10" font-weight="700" fill="#0A0F1E">Today's Stats</text><rect x="252" y="56" width="116" height="45" rx="6" fill="#EBF0FF"/><text x="310" y="75" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="20" font-weight="800" fill="#1557FF">12</text><text x="310" y="90" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">Appointments</text><rect x="252" y="108" width="116" height="45" rx="6" fill="#ECFDF5"/><text x="310" y="127" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="20" font-weight="800" fill="#059669">10</text><text x="310" y="142" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">Confirmed</text><rect x="252" y="160" width="116" height="45" rx="6" fill="#FDF2F8"/><text x="310" y="179" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="20" font-weight="800" fill="#DB2777">1</text><text x="310" y="194" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">No-Show</text><rect x="252" y="212" width="116" height="45" rx="6" fill="#FFF7ED"/><text x="310" y="231" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="20" font-weight="800" fill="#EA580C">1</text><text x="310" y="246" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">Rescheduled</text></svg>
    </div>
  </div>
</section>

<section class="pfeatures" itemscope itemtype="https://schema.org/ItemList">
  <div class="pfeatures-inner">
    <h2>Seamless Scheduling for Every Business</h2>
    <p class="sub">12 powerful features to fill your calendar and delight your customers.</p>
    <ol class="feat-list" role="list">
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="1">
        <div class="feat-ic" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-globe"></i></div>
        <div class="feat-body">
          <span class="feat-num">01</span>
          <h3 itemprop="name">Online Booking</h3>
          <p itemprop="description">Let customers book 24/7 from your website or app. No phone calls needed — bookings come in while you sleep.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="2">
        <div class="feat-ic" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-calendar-days"></i></div>
        <div class="feat-body">
          <span class="feat-num">02</span>
          <h3 itemprop="name">Calendar Sync</h3>
          <p itemprop="description">Sync with Google Calendar, Outlook, and Apple Calendar. Avoid double-bookings with real-time availability.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="3">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-bell"></i></div>
        <div class="feat-body">
          <span class="feat-num">03</span>
          <h3 itemprop="name">SMS / Email Reminders</h3>
          <p itemprop="description">Automated reminders to reduce no-shows by up to 80%. Customizable timing and message templates.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="4">
        <div class="feat-ic" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-credit-card"></i></div>
        <div class="feat-body">
          <span class="feat-num">04</span>
          <h3 itemprop="name">Payments</h3>
          <p itemprop="description">Collect booking fees or full payment at the time of booking. Integrated with popular payment gateways.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="5">
        <div class="feat-ic" style="background:var(--pink-bg);color:var(--pink)"><i class="fa-solid fa-user-xmark"></i></div>
        <div class="feat-body">
          <span class="feat-num">05</span>
          <h3 itemprop="name">No-Show Tracking</h3>
          <p itemprop="description">Track no-shows and manage cancellation policies. Identify repeat offenders and protect your revenue.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="6">
        <div class="feat-ic" style="background:var(--cyan-bg);color:var(--cyan)"><i class="fa-solid fa-location-crosshairs"></i></div>
        <div class="feat-body">
          <span class="feat-num">06</span>
          <h3 itemprop="name">Multi-Location</h3>
          <p itemprop="description">Manage bookings across multiple branches or locations. Centralized view with location-specific availability.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="7">
        <div class="feat-ic" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-tags"></i></div>
        <div class="feat-body">
          <span class="feat-num">07</span>
          <h3 itemprop="name">Service Catalog</h3>
          <p itemprop="description">List services with duration, pricing, and availability. Customers pick exactly what they need before booking.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="8">
        <div class="feat-ic" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-user-clock"></i></div>
        <div class="feat-body">
          <span class="feat-num">08</span>
          <h3 itemprop="name">Staff Scheduling</h3>
          <p itemprop="description">Assign appointments to staff based on skills and availability. Balance workloads automatically.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="9">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-repeat"></i></div>
        <div class="feat-body">
          <span class="feat-num">09</span>
          <h3 itemprop="name">Recurring Bookings</h3>
          <p itemprop="description">Set up weekly, monthly, or custom recurring appointments. Perfect for regular clients and ongoing services.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="10">
        <div class="feat-ic" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-list-ol"></i></div>
        <div class="feat-body">
          <span class="feat-num">10</span>
          <h3 itemprop="name">Waitlist Management</h3>
          <p itemprop="description">Auto-notify customers when slots become available. Fill cancellations instantly without manual follow-up.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="11">
        <div class="feat-ic" style="background:var(--pink-bg);color:var(--pink)"><i class="fa-solid fa-file-lines"></i></div>
        <div class="feat-body">
          <span class="feat-num">11</span>
          <h3 itemprop="name">Custom Forms</h3>
          <p itemprop="description">Collect intake information before the appointment. Custom fields, dropdowns, and file uploads for any workflow.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="12">
        <div class="feat-ic" style="background:var(--cyan-bg);color:var(--cyan)"><i class="fa-solid fa-chart-line"></i></div>
        <div class="feat-body">
          <span class="feat-num">12</span>
          <h3 itemprop="name">Booking Analytics</h3>
          <p itemprop="description">Bookings per day, revenue by service, peak hours analysis. Data-driven insights to optimize your schedule.</p>
        </div>
      </li>
    </ol>
  </div>
</section>

