---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Custom HRMS with Biometric, PF, ESI + TDS | Softwaller";
const description = "Custom HRMS with face recognition attendance, leave automation, PF/ESI/TDS compliance, and DPDP-ready employee self-service. From ₹4L, 6-week deployment.";
const canonical = "https://www.softwaller.com/products/hr-payroll.html";
const ogImage = "https://www.softwaller.com/assets/og-image.jpg";
const ogTitle = "Custom HRMS with Biometric, PF, ESI + TDS | Softwaller";
const ogDescription = "Custom HRMS with face recognition attendance, leave automation, PF/ESI/TDS compliance, and DPDP-ready employee self-service. From ₹4L.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.softwaller.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Services",
        "item": "https://www.softwaller.com/#services"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "HR &amp; Payroll System"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "HR & Payroll System",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Custom HRMS with face recognition attendance, leave automation, PF/ESI/TDS compliance, and DPDP-ready employee self-service. From ₹4L, 6-week deployment.",
    "url": "https://www.softwaller.com/products/hr-payroll.html",
    "provider": {
      "@type": "Organization",
      "name": "Softwaller Technologies Private Limited",
      "url": "https://www.softwaller.com"
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "INR",
      "description": "Free consultation"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does your payroll software handle PF, ESI, PT, TDS, and Form 16?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Statutory components are computed automatically every payroll cycle: PF (12 percent up to wage ceiling), ESI (0.75 percent employee + 3.25 percent employer), state-wise PT, TDS as per slabs, and year-end Form 16 generation."
        }
      },
      {
        "@type": "Question",
        "name": "How does attendance integrate with payroll?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Attendance flows from biometric devices, mobile GPS check-in, RFID, or face recognition into a single dashboard. Leave, overtime, late-coming, and shift premiums automatically reflect in salary calculations."
        }
      },
      {
        "@type": "Question",
        "name": "Is your software DPDP Act compliant for employee data?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We follow DPDP Act 2023 norms: explicit consent capture, role-based access, audit logs, encryption at rest, India data residency, and a defined data retention and deletion policy."
        }
      },
      {
        "@type": "Question",
        "name": "Can employees see payslips and apply for leave on mobile?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The Employee Self-Service (ESS) app on Android and iOS gives access to payslips, Form 16, leave application, attendance correction, IT declaration, and reimbursement claims."
        }
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} ogTitle={ogTitle} ogDescription={ogDescription} jsonLd={jsonLd}>
  <Fragment slot="head-css" set:html={`<link rel="stylesheet" href="../assets/product.min.css?v=1.0.3">`} />
  <style is:global slot="head-css" set:html={`
.faq-section{margin:48px 0 32px;padding:0}
.faq-section h2{font-size:22px;font-weight:800;color:var(--ink);letter-spacing:-.5px;margin:0 0 18px}
.faq-section p.faq-sub{font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.7}
.faq-item{border:1px solid var(--line);border-radius:12px;margin-bottom:10px;background:var(--white);transition:border-color .2s}
.faq-item:hover{border-color:var(--blue-br)}
.faq-item[open]{border-color:var(--blue-br);box-shadow:0 4px 16px rgba(10,15,30,.06)}
.faq-item summary{padding:18px 22px;font-size:15.5px;font-weight:700;color:var(--ink);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;line-height:1.5}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:'\\002B';font-size:22px;font-weight:400;color:var(--blue);flex-shrink:0;transition:transform .2s}
.faq-item[open] summary::after{content:'\\2212'}
.faq-item .faq-answer{padding:0 22px 20px;font-size:14.5px;color:var(--muted);line-height:1.8}
`}></style>
  <Fragment set:html={`
<section class="phero">
  <div class="phero-inner">
    <div class="phero-text">
      <div class="phero-icon" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-users"></i></div>
      <h1>Custom HRMS Built for Indian Statutory Compliance</h1>
      <p>Biometric and face-recognition attendance, payroll with auto PF, ESI, TDS and PT calculations, geo-fenced leave, and branded payslips. Single platform from hire to F&F settlement.</p>
    </div>
    <div class="phero-visual">
      <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><rect width="400" height="300" rx="16" fill="#fff" stroke="#E4E7F0" stroke-width="1.5"/><rect x="20" y="20" width="360" height="36" rx="8" fill="#ECFDF5"/><text x="200" y="43" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="12" font-weight="700" fill="#059669">HR Dashboard — March 2026</text><rect x="25" y="72" width="110" height="62" rx="8" fill="#EBF0FF" stroke="#C2CFFF" stroke-width="1"/><text x="80" y="94" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="20" font-weight="800" fill="#1557FF">248</text><text x="80" y="108" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">Employees</text><text x="80" y="120" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#059669">+12 this month</text><rect x="145" y="72" width="110" height="62" rx="8" fill="#ECFDF5" stroke="#A7F3D0" stroke-width="1"/><text x="200" y="94" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="20" font-weight="800" fill="#059669">94%</text><text x="200" y="108" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">Attendance</text><text x="200" y="120" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#059669">Today</text><rect x="265" y="72" width="110" height="62" rx="8" fill="#F5F3FF" stroke="#DDD6FE" stroke-width="1"/><text x="320" y="94" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="20" font-weight="800" fill="#7C3AED">18</text><text x="320" y="108" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">On Leave</text><text x="320" y="120" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#EA580C">3 pending</text><rect x="25" y="148" width="350" height="48" rx="8" fill="#fff" stroke="#E4E7F0" stroke-width="1"/><text x="40" y="167" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">Payroll Status</text><rect x="40" y="176" width="300" height="10" rx="5" fill="#ECFDF5"/><rect x="40" y="176" width="252" height="10" rx="5" fill="#059669"/><text x="350" y="184" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" font-weight="600" fill="#059669">84%</text><rect x="25" y="208" width="170" height="68" rx="8" fill="#fff" stroke="#E4E7F0" stroke-width="1"/><text x="40" y="230" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">PF/ESI Filed</text><circle cx="172" cy="228" r="10" fill="#ECFDF5"/><text x="172" y="232" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" fill="#059669">&#x2713;</text><text x="40" y="252" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">March 2026 — Submitted</text><text x="40" y="266" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#059669">On time</text><rect x="205" y="208" width="170" height="68" rx="8" fill="#fff" stroke="#E4E7F0" stroke-width="1"/><text x="220" y="230" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">Payslips Sent</text><circle cx="352" cy="228" r="10" fill="#EBF0FF"/><text x="352" y="232" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" fill="#1557FF">&#x2713;</text><text x="220" y="252" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#6B7694">230 / 248 delivered</text><text x="220" y="266" font-family="'Plus Jakarta Sans',sans-serif" font-size="7" fill="#1557FF">93% complete</text></svg>
    </div>
  </div>
</section>

<section class="pfeatures" itemscope itemtype="https://schema.org/ItemList">
