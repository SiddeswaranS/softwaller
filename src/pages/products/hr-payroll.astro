      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="5">
        <div class="feat-ic" style="background:var(--pink-bg);color:var(--pink)"><i class="fa-solid fa-file-lines"></i></div>
        <div class="feat-body">
          <span class="feat-num">05</span>
          <h3 itemprop="name">Payslip Generation</h3>
