        <div class="feat-body">
          <span class="feat-num">01</span>
          <h3 itemprop="name">Biometric Attendance</h3>
          <p itemprop="description">Integration with biometric devices and mobile GPS. Accurate attendance tracking with geo-fencing support.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="2">
        <div class="feat-ic" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-calendar-check"></i></div>
        <div class="feat-body">
          <span class="feat-num">02</span>
          <h3 itemprop="name">Leave Management</h3>
          <p itemprop="description">Leave application, approval workflows, balance tracking, and carryover rules. Fully configurable leave policies.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="3">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-money-check-dollar"></i></div>
