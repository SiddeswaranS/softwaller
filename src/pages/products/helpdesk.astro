        <div class="feat-ic" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-ticket"></i></div>
        <div class="feat-body">
          <span class="feat-num">01</span>
          <h3 itemprop="name">Ticket System</h3>
          <p itemprop="description">Create and manage tickets via email, web form, WhatsApp, or phone with a unified inbox for all channels.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="2">
        <div class="feat-ic" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-hourglass-half"></i></div>
        <div class="feat-body">
          <span class="feat-num">02</span>
          <h3 itemprop="name">SLA Tracking</h3>
          <p itemprop="description">Define response and resolution SLAs with automated escalation alerts when deadlines are approaching.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="3">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-shuffle"></i></div>
        <div class="feat-body">
          <span class="feat-num">03</span>
          <h3 itemprop="name">Auto Assignment</h3>
          <p itemprop="description">Round-robin or skill-based ticket assignment to distribute workload evenly across your support team.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="4">
        <div class="feat-ic" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-book"></i></div>
        <div class="feat-body">
          <span class="feat-num">04</span>
          <h3 itemprop="name">Knowledge Base</h3>
          <p itemprop="description">Searchable help articles and FAQs for customer self-service, reducing ticket volume and wait times.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="5">
        <div class="feat-ic" style="background:var(--pink-bg);color:var(--pink)"><i class="fa-solid fa-face-smile"></i></div>
        <div class="feat-body">
          <span class="feat-num">05</span>
          <h3 itemprop="name">CSAT Surveys</h3>
          <p itemprop="description">Customer satisfaction surveys sent automatically after ticket resolution to measure service quality.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="6">
        <div class="feat-ic" style="background:var(--cyan-bg);color:var(--cyan)"><i class="fa-solid fa-arrow-up-from-bracket"></i></div>
        <div class="feat-body">
          <span class="feat-num">06</span>
          <h3 itemprop="name">Escalation Rules</h3>
          <p itemprop="description">Auto-escalate overdue or high-priority tickets to supervisors with configurable escalation paths.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="7">
        <div class="feat-ic" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-inbox"></i></div>
        <div class="feat-body">
          <span class="feat-num">07</span>
          <h3 itemprop="name">Multi-Channel</h3>
          <p itemprop="description">Unified inbox for email, WhatsApp, web, and phone tickets so no customer query falls through the cracks.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
