        <p>Dashboards &amp; analytics</p>
        <div class="pr-link">Business Intelligence <i class="fa-solid fa-arrow-right"></i></div>
      </a>
    </div>
  </div>
</section>

<section class="pcta">
  <div class="pcta-inner">
    <h2>Have a Custom Requirement?</h2>
    <p>Tell us what you need and we'll build it. Get a free consultation to discuss your idea.</p>
    <a href="/../#contact" class="pcta-btn"><i class="fa-solid fa-paper-plane"></i> Get Free Consultation</a>
  </div>
</section>

