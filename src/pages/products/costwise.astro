---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "CostWise &mdash; Family Expense Tracker for India | Softwaller";
const description = "CostWise — family expense tracker for India. UPI QR scan, GST tracking, multi-language (English, Hindi, Tamil), offline-first. Free with optional Premium.";
const canonical = "https://www.softwaller.com/products/costwise.html";
const ogImage = "https://www.softwaller.com/assets/og-image.jpg";
const ogTitle = "CostWise &mdash; Family Expense Tracker for India";
const ogDescription = "Har Rupee Ka Hisaab. Track family expenses with UPI QR scan, GST split, and Cost-Per-Day insights. Free on Android.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.softwaller.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Products",
        "item": "https://www.softwaller.com/#services"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "CostWise"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "CostWise",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Android",
    "description": "CostWise is a family expense tracker built for India with UPI QR scan, GST tracking, Cost-Per-Day insights, multi-language support (English, Hindi, Tamil), and offline-first architecture.",
    "url": "https://www.softwaller.com/products/costwise.html",
    "inLanguage": [
      "en",
      "hi",
      "ta"
    ],
    "downloadUrl": "https://play.google.com/store/apps/details?id=com.costwise.app",
    "provider": {
      "@type": "Organization",
      "name": "Softwaller Technologies Private Limited",
      "url": "https://www.softwaller.com"
    },
    "offers": [
      {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR",
        "description": "Free Bachat Plan"
      },
      {
        "@type": "Offer",
        "price": "149",
        "priceCurrency": "INR",
        "description": "Premium Parivar Plan — monthly"
      },
      {
        "@type": "Offer",
        "price": "999",
        "priceCurrency": "INR",
        "description": "Premium Parivar Plan — yearly"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is CostWise free to use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The core CostWise app is free on Android and iOS for personal expense tracking, budgets, and reports. Premium features for advanced analytics and multi-account sync are available as in-app upgrades."
        }
      },
      {
        "@type": "Question",
        "name": "Does CostWise sync across multiple devices?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Premium users get encrypted cloud sync across phones, tablets, and a future web dashboard. Free users keep all data securely on the device."
        }
      },
      {
        "@type": "Question",
        "name": "How is my financial data protected?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All data is encrypted at rest with AES-256 and in transit with TLS 1.3. We never sell, share, or analyze user data for ads. You can delete your account and all data at any time from in-app settings."
        }
      },
      {
        "@type": "Question",
        "name": "Can I export my expense data?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Export to CSV, Excel, or PDF anytime. Premium users also get filtered exports by category, account, date range, and tag, plus auto-monthly email reports."
        }
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} ogTitle={ogTitle} ogDescription={ogDescription} jsonLd={jsonLd}>
  <Fragment slot="head-css" set:html={`<link rel="stylesheet" href="../assets/product.min.css?v=1.0.4">`} />
  <style is:global slot="head-css" set:html={`
.faq-section{margin:48px 0 32px;padding:0}
.faq-section h2{font-size:22px;font-weight:800;color:var(--ink);letter-spacing:-.5px;margin:0 0 18px}
.faq-section p.faq-sub{font-size:14px;color:var(--muted);margin-bottom:20px;line-height:1.7}
.faq-item{border:1px solid var(--line);border-radius:12px;margin-bottom:10px;background:var(--white);transition:border-color .2s}
.faq-item:hover{border-color:var(--blue-br)}
.faq-item[open]{border-color:var(--blue-br);box-shadow:0 4px 16px rgba(10,15,30,.06)}
.faq-item summary{padding:18px 22px;font-size:15.5px;font-weight:700;color:var(--ink);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;line-height:1.5}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary::after{content:'\\002B';font-size:22px;font-weight:400;color:var(--blue);flex-shrink:0;transition:transform .2s}
.faq-item[open] summary::after{content:'\\2212'}
.faq-item .faq-answer{padding:0 22px 20px;font-size:14.5px;color:var(--muted);line-height:1.8}
`}></style>
  <Fragment set:html={`
<section class="phero">
  <div class="phero-inner">
    <div class="phero-text">
      <div class="phero-icon" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-wallet"></i></div>
      <h1>CostWise &mdash; Family Expense Tracker for India</h1>
      <p><strong>Har Rupee Ka Hisaab.</strong> Scan any UPI QR, split GST automatically, and see exactly where your family&rsquo;s money goes &mdash; in English, Hindi, or Tamil. Built offline-first so it works without the internet, and made in India for Indian families.</p>
    </div>
    <div class="phero-visual">
      <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg"><rect width="400" height="300" rx="16" fill="#fff" stroke="#E4E7F0" stroke-width="1.5"/><rect x="120" y="20" width="160" height="260" rx="22" fill="#0A0F1E"/><rect x="128" y="30" width="144" height="240" rx="14" fill="#F7F8FC"/><rect x="138" y="44" width="124" height="44" rx="10" fill="#1557FF"/><text x="200" y="64" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="10" font-weight="700" fill="#fff">TODAY&rsquo;S SPEND</text><text x="200" y="82" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="16" font-weight="800" fill="#fff">&#8377;1,240</text><rect x="138" y="98" width="124" height="34" rx="8" fill="#fff" stroke="#E4E7F0"/><text x="146" y="114" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">&#127828; Swiggy</text><text x="146" y="126" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">UPI &middot; Food</text><text x="254" y="120" text-anchor="end" font-family="'Plus Jakarta Sans',sans-serif" font-size="11" font-weight="700" fill="#DC2626">&#8377;340</text><rect x="138" y="138" width="124" height="34" rx="8" fill="#fff" stroke="#E4E7F0"/><text x="146" y="154" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">&#9981; Petrol</text><text x="146" y="166" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">UPI &middot; Fuel</text><text x="254" y="160" text-anchor="end" font-family="'Plus Jakarta Sans',sans-serif" font-size="11" font-weight="700" fill="#DC2626">&#8377;500</text><rect x="138" y="178" width="124" height="34" rx="8" fill="#fff" stroke="#E4E7F0"/><text x="146" y="194" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#0A0F1E">&#128722; Grocery</text><text x="146" y="206" font-family="'Plus Jakarta Sans',sans-serif" font-size="8" fill="#6B7694">Cash &middot; Daily</text><text x="254" y="200" text-anchor="end" font-family="'Plus Jakarta Sans',sans-serif" font-size="11" font-weight="700" fill="#DC2626">&#8377;400</text><rect x="138" y="220" width="124" height="38" rx="10" fill="#ECFDF5" stroke="#A7F3D0"/><text x="200" y="236" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="9" font-weight="700" fill="#059669">CPD &middot; PER PERSON</text><text x="200" y="252" text-anchor="middle" font-family="'Plus Jakarta Sans',sans-serif" font-size="13" font-weight="800" fill="#059669">&#8377;310 / day</text></svg>
    </div>
  </div>
</section>

<section class="pfeatures" itemscope itemtype="https://schema.org/ItemList">
  <div class="pfeatures-inner">
    <h2>Why Indian Families Love CostWise</h2>
    <p class="sub">8 features that make tracking expenses actually feel easy.</p>
    <ol class="feat-list" role="list">
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="1">
        <div class="feat-ic" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-qrcode"></i></div>
        <div class="feat-body">
          <span class="feat-num">01</span>
          <h3 itemprop="name">UPI QR Scan</h3>
          <p itemprop="description">Scan any UPI or payment QR code &mdash; CostWise auto-detects the merchant and pre-fills the amount. No typing, no errors.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="2">
        <div class="feat-ic" style="background:var(--purple-bg);color:var(--purple)"><i class="fa-solid fa-people-roof"></i></div>
        <div class="feat-body">
          <span class="feat-num">02</span>
          <h3 itemprop="name">Family-First</h3>
          <p itemprop="description">Track expenses across every family member. See who spent what, split shared costs, and understand household spending at a glance.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="3">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-receipt"></i></div>
        <div class="feat-body">
          <span class="feat-num">03</span>
          <h3 itemprop="name">GST Tracking</h3>
          <p itemprop="description">Automatically split base amount and tax (CGST/SGST/IGST). Perfect for small business owners and GST-aware households.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="4">
        <div class="feat-ic" style="background:var(--green-bg);color:var(--green)"><i class="fa-solid fa-calendar-day"></i></div>
        <div class="feat-body">
          <span class="feat-num">04</span>
          <h3 itemprop="name">Cost-Per-Day (CPD)</h3>
          <p itemprop="description">See your daily average spend across the whole household. The single number that tells you whether this month is on track.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="5">
        <div class="feat-ic" style="background:var(--pink-bg);color:var(--pink)"><i class="fa-solid fa-language"></i></div>
        <div class="feat-body">
          <span class="feat-num">05</span>
          <h3 itemprop="name">Multi-language</h3>
          <p itemprop="description">Full support for English, Hindi, and Tamil &mdash; with more Indian languages coming soon.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="6">
        <div class="feat-ic" style="background:var(--cyan-bg);color:var(--cyan)"><i class="fa-solid fa-plane-up"></i></div>
        <div class="feat-body">
          <span class="feat-num">06</span>
          <h3 itemprop="name">Offline-First</h3>
          <p itemprop="description">The entire free tier works without internet. Add expenses on a flight, in a basement, anywhere. Sync later if you want.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="7">
        <div class="feat-ic" style="background:var(--blue-bg);color:var(--blue)"><i class="fa-solid fa-shield-halved"></i></div>
        <div class="feat-body">
          <span class="feat-num">07</span>
          <h3 itemprop="name">Privacy by Design</h3>
          <p itemprop="description">Your data stays on your device unless you opt into cloud sync. No ads tracking you, no data sold &mdash; ever.</p>
        </div>
      </li>
      <li class="feat-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <meta itemprop="position" content="8">
        <div class="feat-ic" style="background:var(--orange-bg);color:var(--orange)"><i class="fa-solid fa-indian-rupee-sign"></i></div>
        <div class="feat-body">
          <span class="feat-num">08</span>
          <h3 itemprop="name">Made in India for India</h3>
          <p itemprop="description">Indian &#8377; format (1,00,000), UPI native, Hindi tagline, and built by an Indian team that uses it daily.</p>
        </div>
      </li>
    </ol>
  </div>
</section>

<section class="ppremium">
  <div class="ppremium-inner">
    <h2>CostWise Premium &mdash; Parivar Plan</h2>
    <p class="sub">Unlock the full power of CostWise for less than &#8377;3 a day.</p>
    <div class="ppremium-price">
      <div class="ppremium-card">
        <div class="plan">Monthly</div>
        <div class="amt">&#8377;149<small>/month</small></div>
      </div>
      <div class="ppremium-card hi">
        <div class="plan">Yearly &mdash; Best Value</div>
        <div class="amt">&#8377;999<small>/year</small></div>
        <div class="save">Save &#8377;789 (44% off)</div>
      </div>
    </div>
    <ul class="ppremium-list">
      <li><i class="fa-solid fa-check"></i> Cloud sync + multi-device</li>
      <li><i class="fa-solid fa-check"></i> Unlimited family members (free = 3 max)</li>
      <li><i class="fa-solid fa-check"></i> Monthly, yearly &amp; category reports</li>
      <li><i class="fa-solid fa-check"></i> AI insights &mdash; spot unusual spending</li>
      <li><i class="fa-solid fa-check"></i> PDF &amp; Excel exports</li>
      <li><i class="fa-solid fa-check"></i> GST breakdown reports</li>
      <li><i class="fa-solid fa-check"></i> Budget alerts (50% / 90% / 100%)</li>
      <li><i class="fa-solid fa-check"></i> Subscription tracker (Netflix, Jio, Hotstar&hellip;)</li>
      <li><i class="fa-solid fa-check"></i> Receipt photo + OCR (coming soon)</li>
      <li><i class="fa-solid fa-check"></i> Voice expense entry (coming soon)</li>
      <li><i class="fa-solid fa-check"></i> 100% ad-free experience</li>
      <li><i class="fa-solid fa-check"></i> Streak badges &amp; gamification</li>
      <li><i class="fa-solid fa-check"></i> Priority support</li>
    </ul>
  </div>
</section>

<section class="pcta">
  <div class="pcta-inner">
    <h2>Start Tracking Today &mdash; It&rsquo;s Free</h2>
    <p>CostWise is free to download on Android. No credit card, no sign-up required to begin.</p>
    <a href="https://play.google.com/store/apps/details?id=com.costwise.app" class="pcta-btn"><i class="fa-brands fa-google-play"></i> Download CostWise</a>
    <p style="margin-top:14px;font-size:13px;opacity:.8">Coming soon to the Play Store &middot; iOS later</p>
  </div>
</section>

<section class="faq-section" aria-labelledby="faq-heading">
  <div style="max-width:760px;margin:0 auto;padding:0 28px">
    <h2 id="faq-heading">Frequently Asked Questions</h2>
    <p class="faq-sub">Common questions buyers ask before choosing this software.</p>
    <details class="faq-item">
      <summary>Is CostWise free to use?</summary>
      <div class="faq-answer">Yes. The core CostWise app is free on Android and iOS for personal expense tracking, budgets, and reports. Premium features for advanced analytics and multi-account sync are available as in-app upgrades.</div>
    </details>
    <details class="faq-item">
      <summary>Does CostWise sync across multiple devices?</summary>
      <div class="faq-answer">Yes. Premium users get encrypted cloud sync across phones, tablets, and a future web dashboard. Free users keep all data securely on the device.</div>
    </details>
    <details class="faq-item">
      <summary>How is my financial data protected?</summary>
      <div class="faq-answer">All data is encrypted at rest with AES-256 and in transit with TLS 1.3. We never sell, share, or analyze user data for ads. You can delete your account and all data at any time from in-app settings.</div>
    </details>
    <details class="faq-item">
      <summary>Can I export my expense data?</summary>
      <div class="faq-answer">Yes. Export to CSV, Excel, or PDF anytime. Premium users also get filtered exports by category, account, date range, and tag, plus auto-monthly email reports.</div>
    </details>
  </div>
</section>

`} />
</BaseLayout>
