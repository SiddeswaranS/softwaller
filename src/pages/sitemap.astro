const compare = [
  { url: "/compare/custom-erp-vs-tally.html", name: "Custom ERP vs Tally Prime", desc: "When to switch, 3-year cost, migration plan" },
  { url: "/compare/custom-crm-vs-zoho.html",  name: "Custom CRM vs Zoho CRM",    desc: "Per-user fees vs one-time build" },
];

const pricing = [
  { url: "/pricing/custom-erp-cost-india.html", name: "Custom ERP Cost India", desc: "₹3L–₹1.5Cr — full 2026 breakdown" },
  { url: "/pricing/custom-crm-cost-india.html", name: "Custom CRM Cost India", desc: "₹1.5L–₹25L — 3-year TCO vs SaaS" },
