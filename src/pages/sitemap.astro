  { url: "/products/school-management.html",       name: "School & Institute Management", desc: "Students, fees, attendance" },
  { url: "/products/real-estate.html",             name: "Real Estate & Property",        desc: "Listings, leads, site visits, docs" },
  { url: "/products/custom-business-apps.html",    name: "Custom Business Apps",          desc: "Web apps, mobile apps, portals, dashboards" },
  { url: "/products/costwise.html",                name: "CostWise",                      desc: "Family expense tracker for India (Android app)" },
];

const industries = [
  { url: "/industries/manufacturing.html", name: "Manufacturing ERP", desc: "BoM, production, OEE, GST e-invoicing" },
  { url: "/industries/textile-erp.html",   name: "Textile ERP",       desc: "Yarn lots, looms, dye batches, Tirupur job-work" },
  { url: "/industries/jewellery-erp.html", name: "Jewellery ERP",     desc: "Live gold rate, BIS HUID, RFID, old-gold exchange" },
];

const locations = [
