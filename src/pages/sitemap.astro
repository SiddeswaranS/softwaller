  { url: "/locations/coimbatore.html", name: "Coimbatore", desc: "Textile, jewellery & pump manufacturing belt" },
  { url: "/locations/madurai.html",    name: "Madurai",    desc: "Jewellery, clinics & southern TN trade hub" },
  { url: "/locations/salem.html",      name: "Salem",      desc: "Steel, sago & food processing — our HQ city" },
