  { url: SITE + "/about.html",        name: "About Us",     desc: "Company story, team, values, timeline" },
  { url: SITE + "/case-studies.html", name: "Case Studies", desc: "Real projects with measurable results" },
  { url: SITE + "/portfolio.html",    name: "Portfolio",    desc: "Software we've built" },
  { url: SITE + "/industries.html",   name: "Industries",   desc: "6 verticals we serve" },
  { url: SITE + "/blog/",             name: "Blog",         desc: "Insights & resources" },
  { url: SITE + "/#contact",          name: "Contact Us",   desc: "Enquiry form and contact details" },
];

const products = [
  { url: "/products/crm-software.html",            name: "CRM Software",                  desc: "Lead management, sales pipeline, follow-up automation" },
  { url: "/products/erp-solutions.html",           name: "ERP Solutions",                 desc: "Finance, procurement, production, HR integration" },
  { url: "/products/inventory-management.html",    name: "Inventory Management",          desc: "Multi-warehouse, barcode/QR, auto reorder" },
  { url: "/products/warehouse-management.html",    name: "Warehouse Management (WMS)",    desc: "Pick/pack, barcode, stock transfers" },
  { url: "/products/hr-payroll.html",              name: "HR & Payroll",                  desc: "Attendance, leave, payroll, ESI/PF compliance" },
  { url: "/products/gst-billing-accounting.html",  name: "GST Billing & Accounting",      desc: "e-Invoice, e-Way Bill, GSTR exports" },
  { url: "/products/e-commerce.html",              name: "E-Commerce & Online Store",     desc: "Product catalog, payments, orders" },
  { url: "/products/whatsapp-automation.html",     name: "WhatsApp Business Automation",  desc: "Chatbots, bulk messaging, API" },
  { url: "/products/field-service.html",           name: "Field Service & Sales Force",   desc: "GPS tracking, task assignment" },
  { url: "/products/project-management.html",      name: "Project & Task Management",     desc: "Timelines, sprints, team tracking" },
  { url: "/products/helpdesk.html",                name: "Helpdesk & Ticket Management",  desc: "SLA tracking, knowledge base" },
