---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "IRN Generation Guide for ₹5 Cr+ Businesses | Softwaller";
const description = "Screen-by-screen walkthrough of IRN generation on the IRP. JSON schema, three integration paths, the 30-day rule, and rejection codes in one guide.";
const canonical = "https://www.softwaller.com/blog/irn-generation-step-by-step-guide.html";
const ogImage = "https://www.softwaller.com/assets/og-image.jpg";
const ogTitle = "IRN Generation Guide for ₹5 Cr+ Businesses";
const ogDescription = "Screen-by-screen walkthrough of IRN generation on the IRP. JSON schema, three integration paths, the 30-day rule, and rejection codes in one guide.";
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "IRN Generation Guide for Rs 5 Cr+ Businesses",
    "description": "Screen-by-screen walkthrough of IRN generation on the IRP. JSON schema, three integration paths, the 30-day rule, and rejection codes in one guide.",
    "author": {
      "@type": "Organization",
      "name": "Softwaller Technologies"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Softwaller Technologies",
      "url": "https://www.softwaller.com"
    },
    "datePublished": "2026-04-22",
    "dateModified": "2026-04-22",
    "url": "https://www.softwaller.com/blog/irn-generation-step-by-step-guide.html",
    "image": "https://www.softwaller.com/assets/og-image.jpg"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://www.softwaller.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://www.softwaller.com/blog/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "IRN Generation Guide",
        "item": "https://www.softwaller.com/blog/irn-generation-step-by-step-guide.html"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is an IRN in GST e-invoicing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An Invoice Reference Number (IRN) is a 64-character unique hash generated by the Invoice Registration Portal (IRP) for every B2B invoice raised by an e-invoicing-mandated business. It is computed using a SHA-256 algorithm on the supplier GSTIN, financial year, document type, and document number. Without an IRN, a tax invoice is not legally valid under Rule 48(5) of the CGST Rules."
        }
      },
      {
        "@type": "Question",
        "name": "How long do I have to generate an IRN?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "From April 1, 2025, businesses with aggregate turnover of Rs 10 crore or more must report e-invoices to the IRP within 30 days of the invoice date. After 30 days, the IRP rejects the request and IRN generation is permanently blocked for that document. The rule covers invoices, credit notes, and debit notes."
        }
      },
      {
        "@type": "Question",
        "name": "Can I generate an IRN for a back-dated invoice?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, as long as the invoice date is within the last 30 days (for taxpayers above Rs 10 crore turnover). Beyond 30 days, the IRP rejects the document and you cannot recover the IRN. The only remedy is to issue a credit note for the unreported invoice and raise a fresh, current-dated invoice — both of which need their own IRNs."
        }
      },
      {
        "@type": "Question",
        "name": "What are the three modes of IRN generation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "There are three primary modes: (1) Direct API integration between your billing software and the IRP, (2) GSP/ASP route using a GST Suvidha Provider as middleware, and (3) Manual offline upload via the IRP's Excel/JSON tool. API integration is the only viable mode for businesses generating more than 50 invoices per day."
        }
      }
    ]
  }
];
