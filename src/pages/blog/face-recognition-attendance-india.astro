const title = "Face Recognition Attendance India | Softwaller";
const description = "Biometric is fading; face recognition is taking over. What works on a dusty shop floor, accuracy in low light, DPDP rules, and payroll integration.";
const canonical = "https://www.softwaller.com/blog/face-recognition-attendance-india.html";
