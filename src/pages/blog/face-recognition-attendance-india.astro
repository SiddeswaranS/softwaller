    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is face recognition attendance legal in India?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, when collected with employee consent and stored under reasonable security practices. The DPDP Act 2023 classifies facial data as personal data, so consent must be specific, informed, and withdrawable. The Information Technology (Reasonable Security Practices) Rules 2011 also apply."
